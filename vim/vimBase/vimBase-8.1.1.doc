FROM puritys/vimbase:8.1

RUN cd dotfiles; \
    git pull; \
    ./install.sh

COPY files/.vimrc_plugins /root/
COPY files/JavaImp/ /tmp/JavaImp/

# update plugin
RUN rm -rf /root/.vim/plugged/ale/
RUN echo "\n" | vim -u /root/.vimrc_plugins -c :PlugInstall +qall 


ENV BASH_ENV "/root/.bashrc"
ENV PATH "/sbin:/usr/sbin:/usr/local/sbin:/bin:/usr/bin:/usr/local/bin:/usr/local/gradle/bin"

host="VIM"

# ==========
# Set default value
# ==========
if [ "x" == "x$VIM_THEME" ]; then
    VIM_THEME="seoul256"
fi



if [ "x" != "x$VIMRC" ]; then
    cp $VIMRC ~/.vimrc
fi


if [ "x" != "x$VIM_THEME" ] && [ ! -f "/tmp/first_setenv" ]; then
    sed "s/^colors [a-z0-9A-Z_-]*/colors $VIM_THEME/" -i ~/.vimrc_plugins
fi

# set environment for ssh login
env="VIM_THEME=$VIM_THEME\n"
echo -e $env > /root/.ssh/environment

